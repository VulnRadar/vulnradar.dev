# ============================================================================
# VulnRadar Code Owners
# ============================================================================
# Auto-assigns reviewers based on which paths the PR touches.
# VulnRadar is currently a 2-person org (dbcaa, RejectModders); both are
# listed as owners for all paths until sub-teams are created.
# ============================================================================

# Default owner for everything not matched below
*       @dbcaa @RejectModders

# Security-critical paths
/lib/auth/          @dbcaa @RejectModders
/lib/scanner/       @dbcaa @RejectModders
/lib/rate-limiting/ @dbcaa @RejectModders
/lib/billing/       @dbcaa @RejectModders
/app/api/v2/auth/   @dbcaa @RejectModders
/app/api/v2/billing/ @dbcaa @RejectModders
/app/api/v2/webhooks/ @dbcaa @RejectModders

# Configuration changes
/lib/config/        @dbcaa @RejectModders
/.env.example       @dbcaa @RejectModders
/next.config.mjs    @dbcaa @RejectModders
/Dockerfile         @dbcaa @RejectModders
/docker-compose.yml @dbcaa @RejectModders

# CI / infrastructure
/.github/           @dbcaa @RejectModders

# Database migrations
/lib/database/      @dbcaa @RejectModders
/scripts/migrate.mjs @dbcaa @RejectModders
/scripts/create-fresh-db.mjs @dbcaa @RejectModders
