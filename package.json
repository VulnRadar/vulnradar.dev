{
  "name": "vulnradar",
  "version": "2.3.0",
  "description": "Professional open-source web vulnerability scanner",
  "private": true,
  "engines": {
    "node": ">=20.0.0 <21.0.0 || >=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,css,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,css,yml,yaml}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "node scripts/migrate/migrate.mjs",
    "db:migrate:dry-run": "node scripts/migrate/migrate.mjs --dry-run",
    "db:create": "node scripts/create-fresh-db/create-fresh-db.mjs",
    "db:create:dry-run": "node scripts/create-fresh-db/create-fresh-db.mjs --dry-run",
    "audit:v2-tables": "node scripts/_lib/audit-v2-tables.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "5.4.0",
    "@neondatabase/serverless": "1.1.0",
    "@radix-ui/react-accordion": "1.2.14",
    "@radix-ui/react-alert-dialog": "1.1.17",
    "@radix-ui/react-aspect-ratio": "1.1.10",
    "@radix-ui/react-avatar": "1.2.0",
    "@radix-ui/react-checkbox": "1.3.5",
    "@radix-ui/react-collapsible": "1.1.14",
    "@radix-ui/react-context-menu": "2.3.1",
    "@radix-ui/react-dialog": "1.1.17",
    "@radix-ui/react-dropdown-menu": "2.1.18",
    "@radix-ui/react-hover-card": "1.1.17",
    "@radix-ui/react-label": "2.1.10",
    "@radix-ui/react-menubar": "1.1.18",
    "@radix-ui/react-navigation-menu": "1.2.16",
    "@radix-ui/react-popover": "1.1.17",
    "@radix-ui/react-progress": "1.1.10",
    "@radix-ui/react-radio-group": "1.4.1",
    "@radix-ui/react-scroll-area": "1.2.12",
    "@radix-ui/react-select": "2.3.1",
    "@radix-ui/react-separator": "1.1.10",
    "@radix-ui/react-slider": "1.4.1",
    "@radix-ui/react-slot": "1.3.0",
    "@radix-ui/react-switch": "1.3.1",
    "@radix-ui/react-tabs": "1.1.15",
    "@radix-ui/react-toast": "1.2.17",
    "@radix-ui/react-toggle": "1.1.12",
    "@radix-ui/react-toggle-group": "1.1.13",
    "@radix-ui/react-tooltip": "1.2.10",
    "@stripe/react-stripe-js": "6.6.0",
    "@stripe/stripe-js": "9.8.0",
    "@vitest/coverage-v8": "4.1.9",
    "autoprefixer": "10.5.0",
    "bcrypt": "6.0.0",
    "bcryptjs": "3.0.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "4.4.0",
    "embla-carousel-react": "8.6.0",
    "input-otp": "1.4.2",
    "jsonwebtoken": "9.0.3",
    "jspdf": "4.2.1",
    "jspdf-autotable": "5.0.8",
    "lucide-react": "1.21.0",
    "next": "15.5.19",
    "next-themes": "0.4.6",
    "nodemailer": "^9.0.1",
    "pg": "8.22.0",
    "react": "19.2.7",
    "react-day-picker": "9.14.0",
    "react-dom": "19.2.7",
    "react-hook-form": "7.80.0",
    "react-icons": "5.6.0",
    "react-resizable-panels": "4.11.2",
    "recharts": "3.8.1",
    "server-only": "0.0.1",
    "sonner": "1.7.4",
    "stripe": "22.2.2",
    "swr": "2.4.1",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "3.4.19",
    "tailwindcss-animate": "1.0.7",
    "tslib": "2.8.1",
    "vaul": "1.1.2",
    "vitest": "4.1.9",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "24.13.2",
    "@types/nodemailer": "8.0.1",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.19",
    "postcss": "8.5.15",
    "prettier": "3.8.4",
    "typescript": "5.9.3"
  },
  "overrides": {
    "postcss": "8.5.15",
    "@typescript-eslint/eslint-plugin": "8.0.0",
    "@typescript-eslint/parser": "8.0.0",
    "@typescript-eslint/visitor-keys": "8.0.0",
    "@typescript-eslint/types": "8.0.0"
  }
}
