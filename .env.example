# Database
DATABASE_URL=postgresql://vulnradar:your-strong-password@localhost:5432/vulnradar
DATABASE_SSL=false

# Application URL (exposed to client - required)
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# SMTP Configuration (server-side - optional for email features)
SMTP_HOST=smtp.protonmail.ch
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourdomain.com

# Support and Contact (server-side - optional)
SUPPORT_EMAIL=support@yourdomain.com
CONTACT_EMAIL=support@yourdomain.com

# Turnstile CAPTCHA by Cloudflare (optional)
# Client-side key (exposed to browser)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
# Server-side key (kept secret)
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# API Key Encryption (server-side - required for enhanced security)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY_ENCRYPTION_KEY=your-64-character-hex-key

# Docker-only variables (only needed in docker-compose.yml, not for production deployments)
# POSTGRES_DB=vulnradar
# POSTGRES_USER=vulnradar
# POSTGRES_PASSWORD=your-strong-password
# APP_PORT=3000
# DB_PORT=5432
